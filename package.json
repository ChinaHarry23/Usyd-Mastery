{
  "name": "usyd-mastery",
  "version": "1.0.0",
  "private": true,
  "description": "Interactive study platform for University of Sydney CS courses",
  "scripts": {
    "test": "node tests/test-pure-functions.js && node tests/test-dom-integration.js",
    "test:unit": "node tests/test-pure-functions.js",
    "test:dom": "node tests/test-dom-integration.js",
    "lint": "eslint \"shared/**/*.js\" \"scripts/**/*.js\" \"tests/**/*.js\"",
    "lint:fix": "eslint --fix \"shared/**/*.js\" \"scripts/**/*.js\" \"tests/**/*.js\"",
    "format": "prettier --write \"shared/**/*.{js,css}\" \"scripts/**/*.js\" \"tests/**/*.js\" \"*.js\"",
    "format:check": "prettier --check \"shared/**/*.{js,css}\" \"scripts/**/*.js\" \"tests/**/*.js\" \"*.js\"",
    "validate": "node scripts/validate.js && node scripts/validate-manifest.js",
    "validate:sync": "bash scripts/sync-shared.sh --check",
    "ci": "npm run lint && npm run validate && npm test && npm run validate:sync"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "jsdom": "^27.0.1",
    "prettier": "^3.8.1"
  }
}
